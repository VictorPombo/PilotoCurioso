# ═══════════════════════════════════════════════
# PILOTO CURIOSO — Environment Variables
# ═══════════════════════════════════════════════
# Copie para .env.local e preencha:
#   cp .env.example .env.local
# ═══════════════════════════════════════════════

# Supabase (projeto NOVO e isolado)
NEXT_PUBLIC_SUPABASE_URL=https://SEU_PROJETO.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=eyJ...
SUPABASE_SERVICE_ROLE_KEY=eyJ...

# Google Gemini AI (geração de conteúdo)
GEMINI_API_KEY=sua_chave_gemini_aqui

# JWT Secret (auth do admin)
JWT_SECRET=um_segredo_forte_aqui

# Admin credentials
ADMIN_EMAIL=enzo@pilotocurioso.com.br
ADMIN_PASSWORD_HASH=hash_bcrypt_aqui

# Site URL (atualizar quando domínio estiver pronto)
NEXT_PUBLIC_SITE_URL=https://piloto-curioso.vercel.app
